{%- comment -%}
  Fixes: Color scheme integration, overlay logic, typography inheritance, and schema expansion.
{%- endcomment -%}

{%- assign content_position = section.settings.content_position -%}
{%- assign flex_position = 'center' -%}
{%- if content_position == 'left' -%}{%- assign flex_position = 'flex-start' -%}{%- endif -%}
{%- if content_position == 'right' -%}{%- assign flex_position = 'flex-end' -%}{%- endif -%}

{%- assign vertical_alignment = section.settings.vertical_alignment -%}
{%- assign flex_vertical = 'center' -%}
{%- if vertical_alignment == 'top' -%}{%- assign flex_vertical = 'flex-start' -%}{%- endif -%}
{%- if vertical_alignment == 'bottom' -%}{%- assign flex_vertical = 'flex-end' -%}{%- endif -%}

{%- assign overlay_color = section.settings.overlay_color -%}

<style>
  #shopify-section-{{ section.id }} {
    --hero-height: {{ section.settings.section_height }};
    --content-max-width: {{ section.settings.content_max_width }}px;
    --content-position: {{ flex_position }};
    --vertical-alignment: {{ flex_vertical }};

    /* Overlay RGB extraction for smooth gradients */
    --overlay-color-rgb: {{ overlay_color.red }}, {{ overlay_color.green }}, {{ overlay_color.blue }};
    --gradient-direction: {{ section.settings.gradient_direction }};

    --content-gap: {{ section.settings.content_gap }}px;
    --text-spacing: {{ section.settings.text_spacing }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;

    --heading-size: {{ section.settings.heading_size }}px;
    --heading-weight: {{ section.settings.heading_weight }};
    --letter-spacing: {{ section.settings.letter_spacing }}em;
    --subtitle-size: {{ section.settings.subtitle_size }}px;

    --button-radius: {{ section.settings.button_radius }}px;

    --autoplay-speed: {{ section.settings.autoplay_speed }}s;
    --transition-speed: {{ section.settings.animation_speed }}ms;
  }

  .premium-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: var(--hero-height);
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .premium-hero-{{ section.id }}__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-speed) ease, visibility var(--transition-speed) ease;
    z-index: 1;
    display: flex;
    align-items: center;
  }

  .premium-hero-{{ section.id }}__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .premium-hero-{{ section.id }}__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: -1;
  }

  .premium-hero-{{ section.id }}__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    will-change: transform;
  }

  {% if section.settings.animation_enable %}
    .premium-hero-{{ section.id }}__bg-img {
      transform: scale(1.1);
      transition: transform calc(var(--autoplay-speed) + 1s) cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .premium-hero-{{ section.id }}__slide.is-active .premium-hero-{{ section.id }}__bg-img {
      transform: scale(1);
    }
  {% else %}
    .premium-hero-{{ section.id }}__bg-img {
      transform: scale(1);
    }
  {% endif %}

  .premium-hero-{{ section.id }}__overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      var(--gradient-direction),
      rgba(var(--overlay-color-rgb), 0.2) 0%,
      rgba(var(--overlay-color-rgb), 0.6) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .premium-hero-{{ section.id }}__overlay-solid {
    position: absolute;
    inset: 0;
    background-color: rgba(var(--overlay-color-rgb), 1);
    z-index: 1;
    pointer-events: none;
  }

  .premium-hero-{{ section.id }}__content-wrapper {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--padding-top) 40px var(--padding-bottom);
    display: flex;
    flex-direction: column;
    justify-content: var(--vertical-alignment);
    align-items: var(--content-position);
  }

  .premium-hero-{{ section.id }}__content {
    width: 100%;
    max-width: var(--content-max-width);
    display: flex;
    flex-direction: column;
  }

  .premium-hero-{{ section.id }}__subtitle {
    font-family: var(--font-heading-family, inherit);
    font-size: var(--subtitle-size);
    font-weight: 600;
    letter-spacing: var(--letter-spacing);
    text-transform: uppercase;
    margin-bottom: var(--text-spacing);
    color: white;
    line-height: 1.7;
  }

  .premium-hero-{{ section.id }}__title {
    font-family: var(--font-heading-family, inherit);
    font-size: var(--heading-size);
    font-weight: var(--heading-weight);
    letter-spacing: var(--letter-spacing);
    text-transform: uppercase;
    line-height: 1.3;
    margin-top: 0;
    margin-bottom: var(--content-gap);
    color: white;
  }

  .premium-hero-{{ section.id }}__btn-wrapper--left { justify-content: flex-start; }
  .premium-hero-{{ section.id }}__btn-wrapper--center { justify-content: center; }
  .premium-hero-{{ section.id }}__btn-wrapper--right { justify-content: flex-end; }

  .premium-hero-{{ section.id }}__scroll-down {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 48px;
    height: 48px;
    background-color: white;
    color: black;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    cursor: pointer;
    z-index: 10;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    overflow: hidden;
    transition: background-color 0.3s ease;
  }

  .premium-hero-{{ section.id }}__scroll-down svg {
    display: block;
    animation: arrowScrollOut 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .premium-hero-{{ section.id }}__scroll-down:hover svg {
    animation: arrowScrollIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes arrowScrollIn {
    0% { transform: translateY(0); opacity: 1; }
    45% { transform: translateY(25px); opacity: 0; }
    50% { transform: translateY(-25px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes arrowScrollOut {
    0% { transform: translateY(0); opacity: 1; }
    45% { transform: translateY(25px); opacity: 0; }
    50% { transform: translateY(-25px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* --- Professional Dots Indicator --- */
  .premium-hero-{{ section.id }}__dots {
    position: absolute;
    bottom: 40px;
    right: 40px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .premium-hero-{{ section.id }}__dot {
    position: relative;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  .premium-hero-{{ section.id }}__dot-inner {
    width: 10px;
    height: 10px;
    background-color: #fff;
    border-radius: 50%;
    opacity: 0.4;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .premium-hero-{{ section.id }}__dot.is-active .premium-hero-{{ section.id }}__dot-inner {
    opacity: 1;
    transform: scale(1.2);
  }

  .premium-hero-{{ section.id }}__progress {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .premium-hero-{{ section.id }}__dot.is-active .premium-hero-{{ section.id }}__progress {
    opacity: 1;
  }

  .premium-hero-{{ section.id }}__progress-bg {
    stroke: rgba(255, 255, 255, 0.15);
    stroke-width: 1.5;
  }

  .premium-hero-{{ section.id }}__progress-circle {
    stroke: #ffffff;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-dasharray: 62.83;
    stroke-dashoffset: 62.83;
  }

  .premium-hero-{{ section.id }}__dot.is-active .premium-hero-{{ section.id }}__progress-circle {
    animation: progressRing-{{ section.id }} var(--autoplay-speed) linear forwards;
  }

  @keyframes progressRing-{{ section.id }} {
    from { stroke-dashoffset: 62.83; }
    to { stroke-dashoffset: 0; }
  }

  /* --- FIXED PREMIUM BUTTON STYLES --- */
  .premium-hero-{{ section.id }}__btn {
    position: relative;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background-color: transparent;
    text-decoration: none;
    overflow: hidden;
    letter-spacing: 2.88px;
    border: 1px solid #ffffff;
    padding: 10px 28px;
    isolation: isolate;
    transition: transform 0.2s ease-out;
    border-radius: var(--button-radius);
    font-size: 13px !important;
  }

  .premium-hero-{{ section.id }}__btn:active {
    transform: scale(0.98);
  }

  .premium-hero-{{ section.id }}__btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: #ffffff;
    z-index: -1;
    transform-origin: left center;
    transform: scaleX(1);
    transition: transform 0.45s cubic-bezier(0.76, 0, 0.24, 1);
  }

  .premium-hero-{{ section.id }}__btn:hover::before {
    transform-origin: right center;
    transform: scaleX(0);
  }

  .premium-hero-{{ section.id }}__btn-text {
    color: #000000;
    position: relative;
    z-index: 1;
    transition: color 0.45s ease;
  }

  .premium-hero-{{ section.id }}__btn:hover .premium-hero-{{ section.id }}__btn-text {
    color: #ffffff;
  }

  /* Responsive */
  @media screen and (max-width: 768px) {
    .premium-hero-{{ section.id }}__content-wrapper {
      padding: var(--padding-top) 20px var(--padding-bottom);
    }

    .premium-hero-{{ section.id }}__title {
      font-size: clamp(32px, 8vw, var(--heading-size));
    }

    .premium-hero-{{ section.id }}__subtitle {
      font-size: clamp(10px, 3vw, var(--subtitle-size));
    }

    .premium-hero-{{ section.id }}__dots {
      right: 50%;
      transform: translateX(50%);
      bottom: 20px;
    }

    .premium-hero-{{ section.id }}__scroll-down {
      display: none;
    }

    .premium-hero-{{ section.id }}__overlay-gradient {
      background: linear-gradient(0deg, rgba(var(--overlay-color-rgb), 1) 0%, rgba(var(--overlay-color-rgb), 0) 100%);
    }
  }
</style>

<div
  class="premium-hero-{{ section.id }} color-{{ section.settings.color_scheme }} gradient"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.slider_autoplay }}"
  data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
>
  {%- for block in section.blocks -%}
    {%- assign is_active = false -%}
    {%- if forloop.first -%}{%- assign is_active = true -%}{%- endif -%}

    {%- assign text_align = block.settings.text_alignment | default: section.settings.text_alignment -%}
    {%- assign flex_align = 'center' -%}
    {%- if text_align == 'left' -%}{%- assign flex_align = 'flex-start' -%}{%- endif -%}
    {%- if text_align == 'right' -%}{%- assign flex_align = 'flex-end' -%}{%- endif -%}

    {%- assign slide_overlay_opacity = section.settings.overlay_opacity -%}
    {%- if block.settings.show_custom_overlay -%}
      {%- assign slide_overlay_opacity = block.settings.overlay_opacity -%}
    {%- endif -%}

    <div
      class="premium-hero-{{ section.id }}__slide {% if is_active %}is-active{% endif %}"
      {{ block.shopify_attributes }}
    >
      <div class="premium-hero-{{ section.id }}__bg">
        {%- if section.settings.overlay_toggle -%}
          <div
            class="premium-hero-{{ section.id }}__overlay-solid"
            style="opacity: {{ slide_overlay_opacity | divided_by: 100.0 }};"
          ></div>
          <div
            class="premium-hero-{{ section.id }}__overlay-gradient"
            style="opacity: {{ slide_overlay_opacity | divided_by: 100.0 }};"
          ></div>
        {%- endif -%}

        {%- if block.settings.image != blank -%}
          {%- assign loading_attr = 'lazy' -%}
          {%- if is_active -%}{%- assign loading_attr = 'eager' -%}{%- endif -%}

          {%- comment -%} DYNAMIC CLASS ASSIGNMENT TO FIX LIQUID NESTING ERROR {%- endcomment -%}
          {%- assign bg_img_class = 'premium-hero-' | append: section.id | append: '__bg-img' -%}

          {{
            block.settings.image
            | image_url: width: 3000
            | image_tag: class: bg_img_class, loading: loading_attr, fetchpriority: 'high'
          }}
        {%- else -%}
          {%- comment -%} DYNAMIC CLASS ASSIGNMENT TO FIX LIQUID NESTING ERROR {%- endcomment -%}
          {%- assign placeholder_class = 'premium-hero-' | append: section.id | append: '__bg-img' -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: placeholder_class }}
        {%- endif -%}
      </div>

      <div class="premium-hero-{{ section.id }}__content-wrapper">
        <div
          class="premium-hero-{{ section.id }}__content"
          style="text-align: {{ text_align }}; align-items: {{ flex_align }};"
        >
          {%- if block.settings.subtitle != blank -%}
            <div class="premium-hero-{{ section.id }}__subtitle">{{ block.settings.subtitle }}</div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h2 class="premium-hero-{{ section.id }}__title">{{ block.settings.heading }}</h2>
          {%- endif -%}

          {%- assign btn_text = block.settings.button_text | default: section.settings.button_text -%}
          {%- assign btn_link = block.settings.button_link | default: section.settings.button_link -%}

          {%- if btn_text != blank and btn_link != blank -%}
            <div class="premium-hero-{{ section.id }}__btn-wrapper premium-hero-{{ section.id }}__btn-wrapper--{{ text_align }}">
              <a
                href="{{ btn_link }}"
                class="button button--{{ section.settings.button_style }} premium-hero-{{ section.id }}__btn premium-hero-{{ section.id }}__btn--{{ section.settings.button_size }}"
              >
                <span class="premium-hero-{{ section.id }}__btn-text">{{ btn_text }}</span>
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endfor -%}

  <button class="premium-hero-{{ section.id }}__scroll-down" aria-label="Scroll to next section">
    <svg width="14" height="14" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  {%- if section.blocks.size > 1 -%}
    <div class="premium-hero-{{ section.id }}__dots">
      {%- for block in section.blocks -%}
        <button
          class="premium-hero-{{ section.id }}__dot {% if forloop.first %}is-active{% endif %}"
          aria-label="Go to slide {{ forloop.index }}"
        >
          <span class="premium-hero-{{ section.id }}__dot-inner"></span>
          <svg class="premium-hero-{{ section.id }}__progress" viewBox="0 0 24 24">
            <circle class="premium-hero-{{ section.id }}__progress-bg" cx="12" cy="12" r="10" fill="none" />
            <circle class="premium-hero-{{ section.id }}__progress-circle" cx="12" cy="12" r="10" fill="none" />
          </svg>
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

<script>
  // Dynamically scoped JavaScript Class to prevent 'already been declared' errors when multiple sections are used.
  class PremiumHeroSlider_{{ section.id | replace: '-', '_' }} {
    constructor(container) {
      this.container = container;
      this.slides = this.container.querySelectorAll('.premium-hero-{{ section.id }}__slide');
      this.dots = this.container.querySelectorAll('.premium-hero-{{ section.id }}__dot');
      this.scrollBtn = this.container.querySelector('.premium-hero-{{ section.id }}__scroll-down');

      this.autoplay = this.container.dataset.autoplay === 'true';
      this.speed = parseInt(this.container.dataset.speed) || 5000;
      this.currentIndex = 0;
      this.timer = null;

      if (this.slides.length > 0) {
        this.init();
      }
    }

    init() {
      if (this.dots.length > 0) {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });
      }

      if (this.scrollBtn) {
        this.scrollBtn.addEventListener('click', () => {
          const nextSection = this.container.parentElement.nextElementSibling;
          if (nextSection) {
            const offsetTop = nextSection.getBoundingClientRect().top + window.pageYOffset;
            window.scrollTo({ top: offsetTop, behavior: 'smooth' });
          } else {
            window.scrollBy({ top: window.innerHeight, behavior: 'smooth' });
          }
        });
      }

      if (this.slides.length > 1 && this.autoplay) {
        this.startAutoplay();
      }
    }

    goToSlide(index) {
      if (index === this.currentIndex) return;

      clearTimeout(this.timer);

      this.slides[this.currentIndex].classList.remove('is-active');
      if (this.dots.length > 0) {
        this.dots[this.currentIndex].classList.remove('is-active');
      }

      this.currentIndex = index;

      this.slides[this.currentIndex].classList.add('is-active');
      if (this.dots.length > 0) {
        void this.dots[this.currentIndex].offsetWidth; // Trigger reflow for animation
        this.dots[this.currentIndex].classList.add('is-active');
      }

      if (this.autoplay) {
        this.startAutoplay();
      }
    }

    nextSlide() {
      let nextIndex = this.currentIndex + 1;
      if (nextIndex >= this.slides.length) {
        nextIndex = 0;
      }
      this.goToSlide(nextIndex);
    }

    startAutoplay() {
      clearTimeout(this.timer);
      this.timer = setTimeout(() => {
        this.nextSlide();
      }, this.speed);
    }
  }

  // Initialize specifically for this section
  document.addEventListener('DOMContentLoaded', () => {
    const heroContainer = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (heroContainer) {
      new PremiumHeroSlider_{{ section.id | replace: '-', '_' }}(heroContainer);
    }
  });

  // Re-initialize if edited in Shopify Theme Editor
  document.addEventListener('shopify:section:load', (event) => {
    if (event.detail.sectionId === '{{ section.id }}') {
      const hero = event.target.querySelector('.premium-hero-{{ section.id }}');
      if (hero) {
        new PremiumHeroSlider_{{ section.id | replace: '-', '_' }}(hero);
      }
    }
  });
</script>

{% schema %}
{
  "name": "Premium Hero Banner",
  "tag": "section",
  "class": "section-premium-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        { "value": "600px", "label": "600px" },
        { "value": "800px", "label": "800px" },
        { "value": "1000px", "label": "1000px" },
        { "value": "100vh", "label": "Full Screen (100vh)" }
      ],
      "default": "100vh"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 600,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Content Max Width",
      "default": 800
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Global Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Gap below Heading",
      "default": 40
    },
    {
      "type": "range",
      "id": "text_spacing",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Gap below Subtitle",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Overlay Settings"
    },
    {
      "type": "checkbox",
      "id": "overlay_toggle",
      "label": "Enable Overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Global Overlay Opacity",
      "default": 40
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient Direction",
      "options": [
        { "value": "90deg", "label": "Left to Right (Dark on Right)" },
        { "value": "270deg", "label": "Right to Left (Dark on Left)" },
        { "value": "0deg", "label": "Bottom to Top (Dark on Top)" },
        { "value": "180deg", "label": "Top to Bottom (Dark on Bottom)" }
      ],
      "default": "90deg"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Heading Size",
